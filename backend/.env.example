# ==============================================================================
# 🐝 BeeBoard 2 — Backend-Konfiguration (.env.example)
# ==============================================================================
# Kopieren Sie diese Datei unter dem Namen '.env' in das gleiche Verzeichnis (backend/)
# und passen Sie die Werte entsprechend Ihrer Umgebung an.
# ==============================================================================

# ------------------------------------------------------------------------------
# 🔐 Sicherheit & Authentifizierung
# ------------------------------------------------------------------------------

# PROJECT_NAME: Name des Projekts, der in der API-Dokumentation angezeigt wird.
# Standard: BeeBoard API
PROJECT_NAME="BeeBoard API"

# SECRET_KEY: Ein geheimer Schlüssel zum sicheren Signieren von JSON Web Tokens (JWT).
# WICHTIG: Ändern Sie diesen Wert für die Produktion in einen langen, zufälligen String!
# (Das Setup-Skript generiert diesen automatisch per Zufall).
SECRET_KEY="supersecretkeychangeinproduction1234567890"

# ALGORITHM: Der zu verwendende Signierungs- und Verschlüsselungsalgorithmus für JWTs.
# Standard: HS256
ALGORITHM="HS256"

# ACCESS_TOKEN_EXPIRE_MINUTES: Die Gültigkeitsdauer der Benutzer-Sitzungs-Token in Minuten.
# 1440 Minuten entspricht genau 24 Stunden.
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ------------------------------------------------------------------------------
# 🗃️ Datenbank
# ------------------------------------------------------------------------------

# DATABASE_URL: Die Verbindungs-URL zur SQLite-Datenbank.
# Standardmäßig wird eine lokale SQLite-Datenbank im Ordner backend/data erstellt.
# Standard: sqlite:///./data/beeboard.db
DATABASE_URL="sqlite:///./data/beeboard.db"

# BEEBOARD_HTTP_PORT: Externer HTTP-Port für Nginx / Docker-Setup (Reverse Proxy).
# Standard: 8080
BEEBOARD_HTTP_PORT=8080

# BEEBOARD_BACKEND_PORT: Externer Port für den Backend-Container im Docker-Setup.
# Standard: 8000
BEEBOARD_BACKEND_PORT=8000

# BEEBOARD_DOCKER_DATA: Host-Verzeichnis für persistente Daten im Docker-Setup.
# Standard: ./docker/data
BEEBOARD_DOCKER_DATA="./docker/data"

# ------------------------------------------------------------------------------
# 🤖 KI-Modell & API-Schlüssel (LiteLLM Integration)
# ------------------------------------------------------------------------------

# LITELLM_MODEL: Das KI-Modell, das für den Assistenten und das Strukturieren von
# Stockkarten-Einträgen aus Freitextnotizen verwendet wird.
# Standard: gemini/gemini-2.5-flash
# Alternative für OpenAI (falls gewünscht): openai/gpt-4o-mini
# Alternative für OpenRouter (falls gewünscht): openrouter/google/gemini-2.5-flash oder openrouter/anthropic/claude-3.5-sonnet
# Alternative für Anthropic (falls gewünscht): anthropic/claude-3-5-sonnet-20241022
LITELLM_MODEL="gemini/gemini-2.5-flash"

# GEMINI_API_KEY: Ihr API-Schlüssel von Google AI Studio für die Nutzung von Gemini.
# Dringend empfohlen für die intelligenten Assistant-Funktionen!
# Holen Sie sich kostenlos einen Schlüssel unter: https://aistudio.google.com/
GEMINI_API_KEY=""

# OPENAI_API_KEY: Ihr OpenAI API-Schlüssel (nur benötigt, falls oben ein openai/-Modell gewählt wurde).
OPENAI_API_KEY=""

# OPENROUTER_API_KEY: Ihr OpenRouter API-Schlüssel (nur benötigt, falls oben ein openrouter/-Modell gewählt wurde).
OPENROUTER_API_KEY=""

# ANTHROPIC_API_KEY: Ihr Anthropic API-Schlüssel (nur benötigt, falls oben ein anthropic/-Modell gewählt wurde).
ANTHROPIC_API_KEY=""

# OPENWEATHERMAP_API_KEY: Ihr API-Schlüssel für OpenWeatherMap, um Wetterdaten in die KI-Analysen einzubeziehen.
# Kostenlosen API-Key erhalten unter: https://home.openweathermap.org/users/sign_up
OPENWEATHERMAP_API_KEY=""

# ------------------------------------------------------------------------------
# 📁 Datei-Uploads
# ------------------------------------------------------------------------------

# UPLOAD_DIR: Pfad zum Verzeichnis, in dem Bilder von Hives (Bienenvölkern) und
# Logbuch-Inspektionen gespeichert und über FastAPI bereitgestellt werden.
# Standard: ./data/uploads
UPLOAD_DIR="./data/uploads"
