FROM node:22-alpine AS build

WORKDIR /app

COPY frontend/package*.json ./
RUN npm install

COPY frontend/ ./
RUN npm run build

FROM nginx:1.27-alpine

# Copy built frontend
COPY --from=build /app/dist/ /usr/share/nginx/html/

# Default Nginx config will be overridden by our custom one via volume in compose
EXPOSE 80
